{
  "name": "tempo",
  "version": "0.1.0",
  "description": "A warm paper-like desktop Pomodoro timer.",
  "main": "dist/main/main/main.js",
  "author": "Tempo",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "npm run build:main && node scripts/dev.mjs",
    "build:main": "node scripts/clean-main.mjs && tsc -p tsconfig.node.json",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "build": "npm run build:main && vite build",
    "dist": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-installer.ps1",
    "dist:installer": "npm run dist",
    "dist:installer:signed": "npm run dist",
    "dist:dir": "npm run build && electron-builder --win dir --config.win.signAndEditExecutable=false",
    "dist:release": "npm run dist:dir && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-release.ps1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.tempo.pomodoro",
    "productName": "Tempo",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
